# Database
DATABASE_URL="postgresql://benji:replace-this-pw@db:5432/benjisaiempire?schema=public"

# NextAuth (Auth.js v5)
AUTH_SECRET="GENERATE_VIA_openssl_rand_hex_32"
AUTH_URL="https://benjisaiempire.com"
AUTH_TRUST_HOST="true"

# Email (magic link sender) — Resend
RESEND_API_KEY="re_..."
EMAIL_FROM="Benji <ben@benjisaiempire.com>"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_INSIDER=""       # auto-filled by `npm run setup-stripe`
STRIPE_PRICE_WHOLESALE=""     # auto-filled by `npm run setup-stripe`

# App
ADMIN_EMAILS="ben@advancedmarketing.co"
NEXT_PUBLIC_SITE_URL="https://benjisaiempire.com"

# JARVIS shorts downloader (yt-dlp). In the Docker image yt-dlp + ffmpeg are
# installed via apk and these can be left unset. Locally, set DOWNLOAD_TMP_DIR
# to a folder on a roomy drive so big merges don't fill the system disk.
# DOWNLOAD_TMP_DIR=""        # e.g. D:\jarvis-downloads\tmp
# YT_DLP_PATH=""             # override the yt-dlp binary path if not on PATH
# YT_DLP_COOKIES=""          # cookies.txt for login-gated posts
# FFMPEG_PATH=""             # override ffmpeg location if not on PATH
