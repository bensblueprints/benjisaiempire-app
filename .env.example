# Database (Supabase Postgres — project awjfvgvppggwqjtfaswk)
# https://supabase.com/dashboard/project/awjfvgvppggwqjtfaswk/settings/database
# Copy URI strings from the dashboard; paste password from 1Password (do not commit).
#
# DATABASE_URL — app runtime (Transaction pooler, port 6543). Coolify + local dev.
# DIRECT_URL   — prisma migrate / db push / studio (direct host, port 5432).
#
# Transaction pooler (Next.js app):
DATABASE_URL="postgresql://postgres.awjfvgvppggwqjtfaswk:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (migrations — host from Supabase "Direct connection"):
DIRECT_URL="postgresql://postgres.awjfvgvppggwqjtfaswk:[YOUR-PASSWORD]@db.awjfvgvppggwqjtfaswk.supabase.co:5432/postgres"
#
# Optional local Postgres: docker compose --profile local-db up
# DATABASE_URL="postgresql://benji:change-me-local-only@db:5432/benjisaiempire?schema=public"
# DIRECT_URL="postgresql://benji:change-me-local-only@db:5432/benjisaiempire?schema=public"

# NextAuth (Auth.js v5)
AUTH_SECRET="GENERATE_VIA_openssl_rand_hex_32"
AUTH_URL="https://benjisaiempire.com"
AUTH_TRUST_HOST="true"

# Email (magic link sender) — Resend
RESEND_API_KEY="re_..."
EMAIL_FROM="Benji <ben@benjisaiempire.com>"

# Payment provider: set USE_AIRWALLEX=true (+ NEXT_PUBLIC_USE_AIRWALLEX=true) to switch checkout to Airwallex.
# Stripe routes remain for legacy subscribers until you confirm cutover.
USE_AIRWALLEX="false"
NEXT_PUBLIC_USE_AIRWALLEX="false"

# Stripe (legacy — optional when USE_AIRWALLEX=true)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_INSIDER=""       # auto-filled by `npm run setup-stripe`
STRIPE_PRICE_WHOLESALE=""     # auto-filled by `npm run setup-stripe`

# Airwallex Billing (required when USE_AIRWALLEX=true) — see AIRWALLEX.md
AIRWALLEX_CLIENT_ID=""
AIRWALLEX_API_KEY=""
AIRWALLEX_WEBHOOK_SECRET=""
AIRWALLEX_LEGAL_ENTITY_ID=""       # Settings → Legal entities (le_...)
AIRWALLEX_PAYMENT_ACCOUNT_ID=""  # Settings → Account details → Account Information (acct_...)
AIRWALLEX_PRICE_INSIDER=""       # Billing → Products → recurring price pri_... ($9/mo)
AIRWALLEX_PRICE_WHOLESALE=""     # Billing → Products → recurring price pri_... ($49/mo)
AIRWALLEX_PRICE_DONE_WITH_YOU_MONTHLY=""  # Done For You Coaching $599/mo (strike $1,000)
AIRWALLEX_PRICE_DONE_WITH_YOU_YEARLY=""   # Done For You Coaching $4,997/yr (strike $9,997)
# Optional hosted checkout links if pri_ IDs not ready yet:
AIRWALLEX_CHECKOUT_DFY_MONTHLY_URL=""
AIRWALLEX_CHECKOUT_DFY_YEARLY_URL=""
AIRWALLEX_SANDBOX="true"         # true → https://api-demo.airwallex.com ; false → production API

# App
ADMIN_EMAILS="ben@advancedmarketing.co"
NEXT_PUBLIC_SITE_URL="https://benjisaiempire.com"

# Optional — deploy / tooling (not required for Next.js runtime)
# NETLIFY_SITE_ID = benjisaiempire-app site only (not goaiempire 6ce082c1-...)
NETLIFY_AUTH_TOKEN="REPLACE_ME_nfp_..."
# Runtime on Netlify (avatar/download blobs) — same site ID as benjisaiempire-app
NETLIFY_SITE_ID=""
GITHUB_TOKEN="REPLACE_ME_ghp_..."
GITHUB_USER="bensblueprints"
ELEVENLABS_API_KEY="REPLACE_ME_sk_..."
CLOUDFLARE_API_TOKEN="REPLACE_ME_cfat_..."
COOLIFY_API_TOKEN="REPLACE_ME_coolify_token"
