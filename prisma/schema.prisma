generator client {
  provider      = "prisma-client-js"
  // Netlify Functions (Node 20) run Amazon Linux + OpenSSL 3
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum Tier {
  FREE
  INSIDER
  WHOLESALE
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  name                 String?
  image                String?
  role                 UserRole   @default(USER)
  tier                 Tier       @default(FREE)
  paymentProvider      String?    // "stripe" | "airwallex"
  stripeCustomerId     String?    @unique
  stripeSubscriptionId String?    @unique
  airwallexBillingCustomerId String? @unique
  airwallexSubscriptionId    String? @unique
  subscriptionStatus   SubStatus?
  emailVerified        DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  accounts             Account[]
  sessions             Session[]
  progress             LessonProgress[]
  posts                Post[]
  postLikes            PostLike[]
  comments             Comment[]
  commentLikes         CommentLike[]
  eventRsvps           EventRsvp[]
}


// NextAuth standard tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description String?  @db.Text
  heroImage   String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(false)
  modules     Module[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Module {
  id        String           @id @default(cuid())
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  summary   String?
  sortOrder Int              @default(0)
  lessons   Lesson[]
  downloads ModuleDownload[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ModuleDownload {
  id        String   @id @default(cuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title     String
  url       String
  fileType  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Download {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  fileType    String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  tier        Tier     @default(INSIDER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id              String           @id @default(cuid())
  moduleId        String
  module          Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug            String
  title           String
  body            Json?            // TipTap JSON document
  videoUrl        String?
  durationMinutes Int?
  sortOrder       Int              @default(0)
  published       Boolean          @default(true)
  resources       LessonResource[]
  progress        LessonProgress[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  @@unique([moduleId, slug])
}

model LessonResource {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  name     String
  url      String
}

model LessonProgress {
  userId      String
  lessonId    String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
  @@id([userId, lessonId])
}

// Community

model Post {
  id        String     @id @default(cuid())
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category  String     @default("General")
  title     String?
  body      String     @db.Text
  pinned    Boolean    @default(false)
  published Boolean    @default(true)
  likes     PostLike[]
  comments  Comment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PostLike {
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@id([userId, postId])
}

model Comment {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String        @db.Text
  likes     CommentLike[]
  createdAt DateTime      @default(now())
}

model CommentLike {
  userId    String
  commentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  @@id([userId, commentId])
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  startsAt    DateTime
  endsAt      DateTime?
  joinUrl     String?
  recurring   String?     // "weekly-tue-thu" etc.
  published   Boolean     @default(true)
  rsvps       EventRsvp[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model EventRsvp {
  userId    String
  eventId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@id([userId, eventId])
}
